# Google Analytics 4 Measurement ID
# Get from analytics.google.com → Admin → Data Streams → your stream
VITE_GA4_ID=G-XXXXXXXXXX

# Supabase connection (client-side, safe to expose — anon key only)
# IMPORTANT: when copying these into GitHub Secrets, paste the raw value
# WITHOUT surrounding quotes. The Supabase JS client validates the URL and
# rejects values like "https://..." (with literal quote characters).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Anthropic API key (server-side only — never expose to client)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional secrets for the daily content engine GitHub workflow ─────────
# These are only read by .github/workflows/daily-content.yml. Missing values
# downgrade to warnings — the engine still publishes content, it just can't
# ping the search engines or write to the run log.

# Bing IndexNow key — generate at https://www.bing.com/indexnow/getstarted
# Pings Bing every time the engine publishes a new page so it gets crawled
# faster. Without this, the script logs a warning and continues.
BING_INDEXNOW_KEY=

# Google Indexing API service account JSON (base64-encoded)
# Cloud Console → IAM & Admin → Service Accounts → create key (JSON) → base64-encode the file.
# Pings Google's Indexing API on publish. Without this, the warning logs and
# the engine still ships — Google will still crawl the new pages eventually
# via the sitemap.
GOOGLE_SERVICE_ACCOUNT_JSON=
